# Backend Environment Configuration
# Copy this file to .env and update with your actual values

# Backend public URL (The public IP/Port of your Vast.ai instance)
BACKEND_URL=http://0.0.0.0:8000
# Frontend URL (The public IP/Domain of your Hostinger VPS)
FRONTEND_URL=http://yourdomain.com

# Server port
PORT=8000

# Raw mode - set to true to bypass AI models and stream raw video
# This is useful for testing or when you want to process video client-side
RAW_MODE=false

# Google Cloud Storage Configuration
GCS_BUCKET_NAME=visionlogix-recordings
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=sheets-466006-60150f89fbb7.json

# Telegram Alert Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Camera configuration (optional)
# Default camera index to use when no camera is specified
# DEFAULT_CAMERA=0
